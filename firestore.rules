rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Valid Auth
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Users Collection: RLS (Users only see their own profile)
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['uid', 'email', 'role']);
      allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'settings']);
    }

    // Global Nerve Chat: E2E Encrypted Sub-resource
    // Users must be authenticated to participate
    match /chats/{chatId}/messages/{msgId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() 
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.isEncrypted == true;
      allow delete: if false; // Immutability for security logs
    }
    
    // Invoices and Assets
    match /assets/{assetId} {
      allow read, write: if isOwner(resource.data.ownerId || request.resource.data.ownerId);
    }
  }
}
